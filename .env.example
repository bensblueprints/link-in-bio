# Link-in-Bio configuration
# Copy to .env (or set as environment variables) — all optional.

# Port the server listens on
PORT=5307

# Password for the /admin panel. CHANGE THIS before deploying publicly.
ADMIN_PASSWORD=admin

# Where the SQLite database + uploads live (defaults to ./data)
# DATA_DIR=/var/lib/link-in-bio

# Mount the whole app under a path prefix, e.g. when reverse-proxied at
# https://yoursite.com/benji. Must also be passed to `npm run build`
# (BASE_PATH=/benji ADMIN_PATH=edit npm run build) so the admin bundle's
# asset paths and API calls match. Leave unset to serve at the domain root.
# BASE_PATH=/benji

# Path segment for the admin/editor UI under BASE_PATH (default: admin).
# With BASE_PATH=/benji and ADMIN_PATH=edit, the editor lives at /benji/edit.
# ADMIN_PATH=edit

# ---------------------------------------------------------------------------
# Hosted (multi-tenant) mode — linkleaf.im. Not used by the self-host product;
# only relevant if APP_MODE=multi and you're running docker-compose.hosted.yml.
# ---------------------------------------------------------------------------
# APP_MODE=multi
# DB_USER=linkleaf
# DB_PASSWORD=changeme_use_a_real_password
# DB_NAME=linkleaf
# DATABASE_URL=postgresql://linkleaf:changeme_use_a_real_password@db:5432/linkleaf
# SESSION_SECRET=changeme_generate_a_random_32_char_string
# WHOP_API_KEY=
# WHOP_WEBHOOK_SECRET=
# PUBLIC_URL=https://linkleaf.im

# Password-reset emails (nodemailer/SMTP). Without these set, reset links are
# only logged server-side (docker logs), not emailed — fine for testing, not
# for production.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL=LinkLeaf <no-reply@linkleaf.im>
